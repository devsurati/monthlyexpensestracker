# ── Local development ──────────────────────────────────────────────────────────
# Leave this unset and the app uses a local SQLite file at data/expenses.db
# TURSO_DATABASE_URL=

# ── Vercel / Production (Turso cloud) ─────────────────────────────────────────
# 1. Create a free account at https://turso.tech
# 2. Run:  turso db create spendly
# 3. Run:  turso db show spendly --url        → paste as TURSO_DATABASE_URL
# 4. Run:  turso db tokens create spendly     → paste as TURSO_AUTH_TOKEN
# 5. Add both to Vercel: Project Settings → Environment Variables

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
